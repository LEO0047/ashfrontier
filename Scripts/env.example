# Ashfrontier macOS 環境變數範例
#
# 使用方式：
#   cp Scripts/env.example .env.local
#   source .env.local
#
# 不要把本機私有路徑或憑證提交到 Git。

export PROJECT_ROOT="/Users/leo/Library/Mobile Documents/com~apple~CloudDocs/Coding/Projects/Ashfrontier"

# UE5 Editor 可執行檔或 UnrealEditor.app 路徑。
# 範例：
# export UE5_EDITOR="/Users/Shared/Epic Games/UE_5.7/Engine/Binaries/Mac/UnrealEditor.app"
# export UE5_EDITOR="/Users/Shared/Epic Games/UE_5.7/Engine/Binaries/Mac/UnrealEditor"
export UE5_EDITOR=""

# UE5 root。若 UE5_EDITOR 已設定，UE5_ROOT 可視需要補上。
# 範例：
# export UE5_ROOT="/Users/Shared/Epic Games/UE_5.7"
export UE5_ROOT=""

# Gate 09 macOS package 輸出目錄。
export ASHFRONTIER_MAC_BUILD_DIR="$PROJECT_ROOT/Builds/macOS"

# Soak test 預設秒數。完整 Gate 09 目標為 1800 秒。
export ASHFRONTIER_SOAK_SECONDS="1800"

# Smoke mode 可用較短時間，供 Gate 00 或快速本機檢查使用。
export ASHFRONTIER_SMOKE_SECONDS="60"
